# BrowserStack App Automate (copy: .env.browserstack.example → .env.browserstack)
RUN_MODE=browserstack
APPIUM_SERVER_URL=https://hub-cloud.browserstack.com/wd/hub

BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
# APK из BS Dashboard → App ID (формат bs://...)
BROWSERSTACK_APP=bs://your-app-id
BS_PROJECT_NAME=Trello Diploma QA
BS_BUILD_NAME=local

PLATFORM_NAME=Android
PLATFORM_VERSION=14.0
DEVICE_NAME=Google Pixel 8
AUTOMATION_NAME=UiAutomator2
NO_RESET=false

APP_PACKAGE=com.trello
# Не com.trello.app.activity.HomeActivity — в актуальном APK такой activity нет
APP_ACTIVITY=com.trello.home.HomeActivity

MOBILE_BS_VISIBLE_TIMEOUT=90
MOBILE_BS_RELOAD_PAUSE=8

# TRELLO_EMAIL, TRELLO_PASSWORD, TRELLO_API_KEY, TRELLO_API_TOKEN — в ../trello_ui/.env
