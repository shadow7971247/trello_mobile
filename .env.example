# Учётные данные Trello/API: ../trello_ui/.env
#
# Профили mobile (отдельные файлы, как в требованиях диплома):
#   copy .env.local.example .env.local          — эмулятор
#   copy .env.lambdatest.example .env.lambdatest  — LambdaTest
#   copy .env.browserstack.example .env.browserstack — BrowserStack
#
# Локальный профиль: copy .env.local.example .env.local
# LambdaTest: copy .env.lambdatest.example .env.lambdatest
# Запуск: pytest -m mobile --run-context local
