# Локальный Appium (скопируйте: copy .env.local.example .env.local)
RUN_MODE=local
APPIUM_SERVER_URL=http://127.0.0.1:4723

PLATFORM_NAME=Android
PLATFORM_VERSION=17
DEVICE_NAME=emulator-5554
AUTOMATION_NAME=UiAutomator2
NO_RESET=true

APP_PACKAGE=com.trello
APP_ACTIVITY=com.trello.home.HomeActivity

MOBILE_LOCAL_VISIBLE_TIMEOUT=30
MOBILE_LOCAL_RELOAD_PAUSE=3

# TRELLO_EMAIL, TRELLO_PASSWORD, TRELLO_API_* — в ../trello_ui/.env
